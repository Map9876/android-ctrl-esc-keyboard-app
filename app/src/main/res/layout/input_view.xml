<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/input_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#E8EAED"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- 第一行：Esc  Tab  Ctrl  Alt  Shift -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="2dp">

        <Button
            android:id="@+id/key_esc"
            style="@style/KeyboardKey.FunctionKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="Esc" />

        <Button
            android:id="@+id/key_tab"
            style="@style/KeyboardKey.FunctionKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="Tab" />

        <Button
            android:id="@+id/key_ctrl"
            style="@style/KeyboardKey.FunctionKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="Ctrl" />

        <Button
            android:id="@+id/key_alt"
            style="@style/KeyboardKey.FunctionKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="Alt" />

        <Button
            android:id="@+id/key_shift"
            style="@style/KeyboardKey.FunctionKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="⇧" />

    </LinearLayout>

    <!-- 第二行：Home  End  PgUp  PgDn  ← ↑ ↓ → ⌨ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="2dp">

        <Button
            android:id="@+id/key_home"
            style="@style/KeyboardKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="Home"
            android:textSize="10sp" />

        <Button
            android:id="@+id/key_end"
            style="@style/KeyboardKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="End"
            android:textSize="10sp" />

        <Button
            android:id="@+id/key_pgup"
            style="@style/KeyboardKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="PgUp"
            android:textSize="10sp" />

        <Button
            android:id="@+id/key_pgdn"
            style="@style/KeyboardKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="PgDn"
            android:textSize="10sp" />

        <Button
            android:id="@+id/key_left"
            style="@style/KeyboardKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="←" />

        <Button
            android:id="@+id/key_up"
            style="@style/KeyboardKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="↑" />

        <Button
            android:id="@+id/key_down"
            style="@style/KeyboardKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="↓" />

        <Button
            android:id="@+id/key_right"
            style="@style/KeyboardKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="→" />

        <Button
            android:id="@+id/key_switch"
            style="@style/KeyboardKey"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_margin="1dp"
            android:text="⌨"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- 第三行：Q W E R T Y U I O P -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="1dp">

        <Button android:id="@+id/key_q" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="Q" />
        <Button android:id="@+id/key_w" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="W" />
        <Button android:id="@+id/key_e" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="E" />
        <Button android:id="@+id/key_r" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="R" />
        <Button android:id="@+id/key_t" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="T" />
        <Button android:id="@+id/key_y" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="Y" />
        <Button android:id="@+id/key_u" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="U" />
        <Button android:id="@+id/key_i" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="I" />
        <Button android:id="@+id/key_o" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="O" />
        <Button android:id="@+id/key_p" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="P" />

    </LinearLayout>

    <!-- 第四行：A S D F G H J K L -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="1dp"
        android:paddingStart="12dp">

        <Button android:id="@+id/key_a" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="A" />
        <Button android:id="@+id/key_s" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="S" />
        <Button android:id="@+id/key_d" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="D" />
        <Button android:id="@+id/key_f" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="F" />
        <Button android:id="@+id/key_g" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="G" />
        <Button android:id="@+id/key_h" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="H" />
        <Button android:id="@+id/key_j" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="J" />
        <Button android:id="@+id/key_k" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="K" />
        <Button android:id="@+id/key_l" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="L" />

    </LinearLayout>

    <!-- 第五行：Z X C V B N M -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="1dp"
        android:paddingStart="24dp">

        <Button android:id="@+id/key_z" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="Z" />
        <Button android:id="@+id/key_x" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="X" />
        <Button android:id="@+id/key_c" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="C" />
        <Button android:id="@+id/key_v" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="V" />
        <Button android:id="@+id/key_b" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="B" />
        <Button android:id="@+id/key_n" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="N" />
        <Button android:id="@+id/key_m" style="@style/KeyboardKey" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_margin="1dp" android:text="M" />

    </LinearLayout>

</LinearLayout>
